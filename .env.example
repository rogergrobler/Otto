ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
CONVERSATION_TIMEOUT_HOURS=4
